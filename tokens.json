{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "name": "spoonLabs AI Brand Tokens",
    "version": "0.1.0",
    "description": "Design tokens for the spoonLabs AI ecosystem",
    "package": "@spoonlabs/brand"
  },
  "color": {
    "purple": {
      "50":  { "$value": "#F0EFFE", "$type": "color", "$description": "Purple lightest" },
      "100": { "$value": "#DDD9FC", "$type": "color" },
      "200": { "$value": "#BEB7F9", "$type": "color" },
      "300": { "$value": "#9A90F5", "$type": "color" },
      "400": { "$value": "#7A6FF0", "$type": "color" },
      "500": { "$value": "#534AB7", "$type": "color", "$description": "Brand primary — deep purple" },
      "600": { "$value": "#4840A3", "$type": "color" },
      "700": { "$value": "#3C368D", "$type": "color" },
      "800": { "$value": "#2E2A6E", "$type": "color" },
      "900": { "$value": "#1D1A45", "$type": "color", "$description": "Purple darkest" }
    },
    "teal": {
      "50":  { "$value": "#E7F8F3", "$type": "color", "$description": "Teal lightest" },
      "100": { "$value": "#C4EEE1", "$type": "color" },
      "200": { "$value": "#8FDDC5", "$type": "color" },
      "300": { "$value": "#55CBAA", "$type": "color" },
      "400": { "$value": "#2EB78F", "$type": "color" },
      "500": { "$value": "#1D9E75", "$type": "color", "$description": "Brand accent — teal" },
      "600": { "$value": "#198A65", "$type": "color" },
      "700": { "$value": "#147554", "$type": "color" },
      "800": { "$value": "#0E5E42", "$type": "color" },
      "900": { "$value": "#08402D", "$type": "color", "$description": "Teal darkest" }
    },
    "gray": {
      "50":  { "$value": "#F8F7F5", "$type": "color", "$description": "Background light / warm white" },
      "100": { "$value": "#EFEEEB", "$type": "color" },
      "200": { "$value": "#DDDCDA", "$type": "color" },
      "300": { "$value": "#C4C3C0", "$type": "color" },
      "400": { "$value": "#A8A7A4", "$type": "color" },
      "500": { "$value": "#5F5E5A", "$type": "color", "$description": "Brand neutral — warm gray" },
      "600": { "$value": "#4D4C49", "$type": "color" },
      "700": { "$value": "#3A3938", "$type": "color" },
      "800": { "$value": "#252423", "$type": "color" },
      "900": { "$value": "#131211", "$type": "color" }
    },
    "dark": {
      "bg": { "$value": "#0D0C0F", "$type": "color", "$description": "Background dark — near-black with purple undertone" }
    },
    "semantic": {
      "light": {
        "bg":           { "$value": "{color.gray.50}",   "$type": "color" },
        "bgSecondary":  { "$value": "#FFFFFF",           "$type": "color" },
        "surface":      { "$value": "#FFFFFF",           "$type": "color" },
        "border":       { "$value": "{color.gray.200}",  "$type": "color" },
        "borderMuted":  { "$value": "{color.gray.100}",  "$type": "color" },
        "text":         { "$value": "{color.gray.900}",  "$type": "color" },
        "textMuted":    { "$value": "{color.gray.500}",  "$type": "color" },
        "textSubtle":   { "$value": "{color.gray.400}",  "$type": "color" },
        "primary":      { "$value": "{color.purple.500}", "$type": "color" },
        "accent":       { "$value": "{color.teal.500}",  "$type": "color" }
      },
      "dark": {
        "bg":           { "$value": "{color.dark.bg}",   "$type": "color" },
        "bgSecondary":  { "$value": "{color.gray.900}",  "$type": "color" },
        "surface":      { "$value": "#161519",           "$type": "color" },
        "border":       { "$value": "rgba(255,255,255,0.1)", "$type": "color" },
        "borderMuted":  { "$value": "rgba(255,255,255,0.06)", "$type": "color" },
        "text":         { "$value": "{color.gray.50}",   "$type": "color" },
        "textMuted":    { "$value": "{color.gray.400}",  "$type": "color" },
        "textSubtle":   { "$value": "{color.gray.500}",  "$type": "color" },
        "primary":      { "$value": "{color.purple.400}", "$type": "color" },
        "accent":       { "$value": "{color.teal.400}",  "$type": "color" }
      }
    }
  },
  "typography": {
    "fontFamily": {
      "mono":    { "$value": "'Space Mono', 'JetBrains Mono', 'Fira Code', 'Courier New', monospace", "$type": "fontFamily", "$description": "Code, UI accents, technical labels" },
      "body":    { "$value": "'DM Sans', 'Inter', 'Segoe UI', system-ui, sans-serif",                 "$type": "fontFamily", "$description": "Body text, paragraphs, UI prose" },
      "display": { "$value": "'DM Sans', 'Inter', system-ui, sans-serif",                             "$type": "fontFamily", "$description": "Headlines and display text" }
    },
    "fontSize": {
      "xs":   { "$value": "0.75rem",   "$type": "dimension", "$description": "12px" },
      "sm":   { "$value": "0.875rem",  "$type": "dimension", "$description": "14px" },
      "base": { "$value": "1rem",      "$type": "dimension", "$description": "16px" },
      "lg":   { "$value": "1.125rem",  "$type": "dimension", "$description": "18px" },
      "xl":   { "$value": "1.25rem",   "$type": "dimension", "$description": "20px" },
      "2xl":  { "$value": "1.5rem",    "$type": "dimension", "$description": "24px" },
      "3xl":  { "$value": "1.875rem",  "$type": "dimension", "$description": "30px" },
      "4xl":  { "$value": "2.25rem",   "$type": "dimension", "$description": "36px" },
      "5xl":  { "$value": "3rem",      "$type": "dimension", "$description": "48px" },
      "6xl":  { "$value": "3.75rem",   "$type": "dimension", "$description": "60px" }
    },
    "fontWeight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    },
    "lineHeight": {
      "tight":   { "$value": 1.25,  "$type": "number" },
      "snug":    { "$value": 1.375, "$type": "number" },
      "normal":  { "$value": 1.5,   "$type": "number" },
      "relaxed": { "$value": 1.625, "$type": "number" },
      "loose":   { "$value": 2,     "$type": "number" }
    },
    "letterSpacing": {
      "tighter": { "$value": "-0.05em",  "$type": "dimension" },
      "tight":   { "$value": "-0.025em", "$type": "dimension" },
      "normal":  { "$value": "0em",      "$type": "dimension" },
      "wide":    { "$value": "0.025em",  "$type": "dimension" },
      "wider":   { "$value": "0.05em",   "$type": "dimension" },
      "widest":  { "$value": "0.1em",    "$type": "dimension" }
    }
  },
  "spacing": {
    "px":  { "$value": "1px",     "$type": "dimension" },
    "0":   { "$value": "0",       "$type": "dimension" },
    "0-5": { "$value": "0.125rem","$type": "dimension", "$description": "2px" },
    "1":   { "$value": "0.25rem", "$type": "dimension", "$description": "4px" },
    "1-5": { "$value": "0.375rem","$type": "dimension", "$description": "6px" },
    "2":   { "$value": "0.5rem",  "$type": "dimension", "$description": "8px" },
    "2-5": { "$value": "0.625rem","$type": "dimension", "$description": "10px" },
    "3":   { "$value": "0.75rem", "$type": "dimension", "$description": "12px" },
    "3-5": { "$value": "0.875rem","$type": "dimension", "$description": "14px" },
    "4":   { "$value": "1rem",    "$type": "dimension", "$description": "16px" },
    "5":   { "$value": "1.25rem", "$type": "dimension", "$description": "20px" },
    "6":   { "$value": "1.5rem",  "$type": "dimension", "$description": "24px" },
    "7":   { "$value": "1.75rem", "$type": "dimension", "$description": "28px" },
    "8":   { "$value": "2rem",    "$type": "dimension", "$description": "32px" },
    "9":   { "$value": "2.25rem", "$type": "dimension", "$description": "36px" },
    "10":  { "$value": "2.5rem",  "$type": "dimension", "$description": "40px" },
    "11":  { "$value": "2.75rem", "$type": "dimension", "$description": "44px" },
    "12":  { "$value": "3rem",    "$type": "dimension", "$description": "48px" },
    "14":  { "$value": "3.5rem",  "$type": "dimension", "$description": "56px" },
    "16":  { "$value": "4rem",    "$type": "dimension", "$description": "64px" },
    "20":  { "$value": "5rem",    "$type": "dimension", "$description": "80px" },
    "24":  { "$value": "6rem",    "$type": "dimension", "$description": "96px" },
    "32":  { "$value": "8rem",    "$type": "dimension", "$description": "128px" }
  },
  "borderRadius": {
    "none": { "$value": "0",        "$type": "dimension" },
    "sm":   { "$value": "0.125rem", "$type": "dimension", "$description": "2px" },
    "base": { "$value": "0.25rem",  "$type": "dimension", "$description": "4px" },
    "md":   { "$value": "0.375rem", "$type": "dimension", "$description": "6px" },
    "lg":   { "$value": "0.5rem",   "$type": "dimension", "$description": "8px" },
    "xl":   { "$value": "0.75rem",  "$type": "dimension", "$description": "12px" },
    "2xl":  { "$value": "1rem",     "$type": "dimension", "$description": "16px" },
    "3xl":  { "$value": "1.5rem",   "$type": "dimension", "$description": "24px" },
    "full": { "$value": "9999px",   "$type": "dimension", "$description": "Pill shape" }
  },
  "shadow": {
    "sm":     { "$value": "0 1px 2px 0 rgba(0,0,0,0.05)",                                                       "$type": "shadow" },
    "base":   { "$value": "0 1px 3px 0 rgba(0,0,0,0.1), 0 1px 2px -1px rgba(0,0,0,0.1)",                       "$type": "shadow" },
    "md":     { "$value": "0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.1)",                    "$type": "shadow" },
    "lg":     { "$value": "0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1)",                  "$type": "shadow" },
    "xl":     { "$value": "0 20px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.1)",                 "$type": "shadow" },
    "2xl":    { "$value": "0 25px 50px -12px rgba(0,0,0,0.25)",                                                 "$type": "shadow" },
    "inner":  { "$value": "inset 0 2px 4px 0 rgba(0,0,0,0.05)",                                                 "$type": "shadow" },
    "none":   { "$value": "none",                                                                                "$type": "shadow" },
    "purpleSm": { "$value": "0 0 0 3px rgba(83,74,183,0.2)",    "$type": "shadow", "$description": "Focus ring" },
    "purpleMd": { "$value": "0 0 12px 0 rgba(83,74,183,0.35)",  "$type": "shadow", "$description": "Hover glow" },
    "purpleLg": { "$value": "0 0 24px 0 rgba(83,74,183,0.5)",   "$type": "shadow", "$description": "Active glow" }
  },
  "transition": {
    "fast":   { "$value": "150ms ease",  "$type": "transition" },
    "base":   { "$value": "200ms ease",  "$type": "transition" },
    "slow":   { "$value": "300ms ease",  "$type": "transition" },
    "slower": { "$value": "500ms ease",  "$type": "transition" },
    "easing": {
      "in":     { "$value": "cubic-bezier(0.4, 0, 1, 1)",          "$type": "cubicBezier" },
      "out":    { "$value": "cubic-bezier(0, 0, 0.2, 1)",           "$type": "cubicBezier" },
      "inOut":  { "$value": "cubic-bezier(0.4, 0, 0.2, 1)",         "$type": "cubicBezier" },
      "spring": { "$value": "cubic-bezier(0.175, 0.885, 0.32, 1.275)", "$type": "cubicBezier" }
    }
  }
}
